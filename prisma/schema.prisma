generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                        String   @id @default("default")
  businessName              String?
  tagline                   String?
  phoneNumber               String?
  whatsappNumber            String?
  email                     String?
  address                   String?
  heroTitle                 String?
  heroSubtitle              String?
  heroImageUrl              String?
  heroImagePath             String?
  aboutTitle                String?
  aboutDescription          String?
  aboutSecondaryDescription String?
  aboutImageUrl             String?
  aboutImagePath            String?
  aboutSecondaryImageUrl    String?
  aboutSecondaryImagePath   String?
  localizedContent          Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  title_he       String   @default("")
  title_ar       String?
  description_he String?
  description_ar String?
  category       String
  location       String?
  image          String?
  gallery        Json?
  isPublished    Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  createdAt      DateTime @default(now())
}
